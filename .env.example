# AI Trend Daily — Configuration
# Copy to .env and fill in your values

# LLM API Keys (at least one required for AI features)
AI_TREND_ANTHROPIC_API_KEY=sk-ant-...
# AI_TREND_OPENAI_API_KEY=sk-...
# AI_TREND_OPENAI_BASE_URL=https://api.deepseek.com

# GitHub (optional, for API enhancement)
AI_TREND_GITHUB_TOKEN=ghp_...

# Notifications (optional)
AI_TREND_TELEGRAM_BOT_TOKEN=
AI_TREND_TELEGRAM_CHAT_ID=
AI_TREND_WEWORK_WEBHOOK_URL=

# Pipeline settings
AI_TREND_REPORT_LANGUAGE=zh
AI_TREND_TOP_N_REPOS=30
AI_TREND_CLASSIFIER_RULES_ONLY=false
