---
export interface Language {
  name: string;
  count: number;
  percentage: number;
}

const { languages } = Astro.props as { languages: Language[] };

const langColors: Record<string, string> = {
  Python: '#3572A5',
  TypeScript: '#3178C6',
  JavaScript: '#F7DF1E',
  Rust: '#DEA584',
  Go: '#00ADD8',
  Jupyter: '#DA5B0B',
};
---

<div class="apple-card px-6 py-5">
  <h3 class="text-sm font-semibold text-[var(--color-apple-text)] tracking-tight mb-5">编程语言分布</h3>
  <div class="space-y-4">
    {languages.map((lang, i) => {
      const color = langColors[lang.name] || '#aeaeb2';
      return (
        <div style={`animation: fadeInUp 0.4s ease ${i * 0.05}s both`}>
          <div class="flex items-center justify-between text-sm mb-1.5">
            <span class="font-medium text-[var(--color-apple-text)]">{lang.name}</span>
            <span class="text-xs text-[var(--color-apple-text-secondary)] tabular-nums">{lang.percentage}%</span>
          </div>
          <div class="apple-progress">
            <div class="apple-progress-bar" style={`width: ${lang.percentage}%; background-color: ${color}`}></div>
          </div>
        </div>
      );
    })}
  </div>
</div>
