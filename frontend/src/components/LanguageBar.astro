---
export interface Language {
  name: string;
  count: number;
  percentage: number;
}

const { languages } = Astro.props as { languages: Language[] };

const langColors: Record<string, string> = {
  Python: '#3572A5',
  TypeScript: '#3178C6',
  JavaScript: '#F7DF1E',
  Rust: '#DEA584',
  Go: '#00ADD8',
  Jupyter: '#DA5B0B',
};
---

<div class="bg-white rounded-lg border border-neutral-200 shadow-sm p-5">
  <h3 class="text-sm font-semibold text-neutral-700 mb-4">编程语言分布</h3>
  <div class="space-y-3">
    {languages.map(lang => {
      const color = langColors[lang.name] || '#94a3b8';
      return (
        <div>
          <div class="flex items-center justify-between text-sm mb-1">
            <span class="font-medium text-neutral-700">{lang.name}</span>
            <span class="text-neutral-500">{lang.percentage}%</span>
          </div>
          <div class="w-full bg-neutral-100 rounded-full h-2 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500" style={`width: ${lang.percentage}%; background-color: ${color}`}></div>
          </div>
        </div>
      );
    })}
  </div>
</div>
