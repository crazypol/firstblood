---
export interface Props {
  label: string;
  value: string | number;
  trend?: string;
  trendUp?: boolean;
  color?: string;
}

const { label, value, trend, trendUp = true, color = 'text-[var(--color-apple-blue)]' } = Astro.props;
---

<div class="apple-card px-5 py-[1.125rem]">
  <p class="text-xs font-medium text-[var(--color-apple-text-secondary)] tracking-wide uppercase mb-0.5">{label}</p>
  <p class={`text-[1.65rem] font-semibold tracking-tight ${color}`}>{value}</p>
  {trend && (
    <p class={`text-xs mt-1 font-medium ${trendUp ? 'text-[var(--color-success)]' : 'text-[var(--color-error)]'}`}>
      {trendUp ? '↑' : '↓'} {trend}
    </p>
  )}
</div>
