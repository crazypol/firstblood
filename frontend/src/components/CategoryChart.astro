---
export interface Category {
  name: string;
  count: number;
  percentage: number;
}

const { categories } = Astro.props as { categories: Category[] };

const colors: Record<string, string> = {
  llm: '#8b5cf6',
  agent: '#06b6d4',
  rag: '#34c759',
  mcp: '#ff9f0a',
  multimodal: '#ff375f',
  ai_tooling: '#0071e3',
  ai_infra: '#8e8e93',
  ai_safety: '#ff453a',
  ml_platform: '#14b8a6',
  reasoning: '#ff9f0a',
  code_generation: '#8b5cf6',
};
---

<div class="apple-card px-6 py-5">
  <h3 class="text-sm font-semibold text-[var(--color-apple-text)] tracking-tight mb-5">AI 子领域分布</h3>
  <div class="space-y-4">
    {categories.map((cat, i) => {
      const color = colors[cat.name] || '#aeaeb2';
      return (
        <div style={`animation: fadeInUp 0.4s ease ${i * 0.05}s both`}>
          <div class="flex items-center justify-between text-sm mb-1.5">
            <span class="font-medium text-[var(--color-apple-text)]">{cat.name}</span>
            <span class="text-xs text-[var(--color-apple-text-secondary)] tabular-nums">{cat.count} ({cat.percentage}%)</span>
          </div>
          <div class="apple-progress">
            <div class="apple-progress-bar" style={`width: ${cat.percentage}%; background-color: ${color}`}></div>
          </div>
        </div>
      );
    })}
  </div>
</div>
