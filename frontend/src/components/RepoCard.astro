---
export interface Repo {
  rank: number;
  name: string;
  url: string;
  description: string;
  language: string;
  stars: number;
  stars_today: number;
  forks: number;
  ai_category: string;
  ai_subcategories: string[];
  summary_zh?: string;
}

const { repo } = Astro.props as { repo: Repo };
const isTop3 = repo.rank >= 1 && repo.rank <= 3;

const catStyle: Record<string, string> = {
  llm: 'bg-[#f0ecff] text-[#6b47d6]',
  agent: 'bg-[#e6f9fc] text-[#0098b3]',
  rag: 'bg-[#e8f8ee] text-[#248a3d]',
  mcp: 'bg-[#fff5e6] text-[#b26200]',
  multimodal: 'bg-[#fce8f0] text-[#ba2d5e]',
  ai_tooling: 'bg-[#e8f0fe] text-[#0055c1]',
  ai_infra: 'bg-[#f0f0f2] text-[#636366]',
  ai_safety: 'bg-[#fce8e8] text-[#ba2d2d]',
  ml_platform: 'bg-[#e6faf5] text-[#00866a]',
  reasoning: 'bg-[#fff0e6] text-[#b24900]',
  code_generation: 'bg-[#f0ecff] text-[#6b47d6]',
};

const style = catStyle[repo.ai_category] || 'bg-[#f0f0f2] text-[#636366]';
---

<div class="apple-card px-6 py-[1.125rem]">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <!-- Rank + Name -->
      <div class="flex items-center gap-2.5 mb-1">
        {isTop3 ? (
          <span class="text-base">{['🥇', '🥈', '🥉'][repo.rank - 1]}</span>
        ) : (
          <span class="text-xs font-semibold text-[var(--color-apple-text-tertiary)] tabular-nums">#{repo.rank}</span>
        )}
        <a href={repo.url} target="_blank" class="text-[0.9375rem] font-semibold text-[var(--color-apple-text)] hover:text-[var(--color-apple-blue)] transition-colors duration-200 truncate no-underline tracking-tight">
          {repo.name}
        </a>
      </div>

      <!-- Description -->
      <p class="text-sm text-[var(--color-apple-text-secondary)] leading-relaxed mb-3">{repo.summary_zh || repo.description}</p>

      <!-- Tags -->
      <div class="flex flex-wrap items-center gap-1.5 mb-3">
        <span class={`apple-pill font-medium ${style}`}>{repo.ai_category}</span>
        {repo.ai_subcategories?.slice(0, 2).map(s => (
          <span class="apple-pill bg-[var(--color-apple-gray-fill)] text-[var(--color-apple-text-secondary)]">{s}</span>
        ))}
        {repo.language && (
          <span class="apple-pill bg-[var(--color-apple-gray-fill)] text-[var(--color-apple-text-secondary)]">{repo.language}</span>
        )}
      </div>

      <!-- Stats -->
      <div class="flex items-center gap-4 text-sm">
        <span class="font-semibold text-[var(--color-apple-text)] tracking-tight">⭐ {repo.stars?.toLocaleString()}</span>
        {repo.stars_today > 0 && <span class="text-[var(--color-success)] font-semibold">+{repo.stars_today} 今日</span>}
        <span class="text-[var(--color-apple-text-tertiary)]">🍴 {repo.forks?.toLocaleString()}</span>
      </div>
    </div>
  </div>
</div>
