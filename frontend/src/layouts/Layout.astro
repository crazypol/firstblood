---
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'AI Trend Daily' } = Astro.props;
const currentDate = new Date().toISOString().split('T')[0];
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — AI Trend Daily</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="description" content="GitHub 热门 AI 相关项目每日趋势统计" />
  </head>
  <body class="min-h-screen">
    <!-- Nav -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-neutral-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/firstblood/" class="flex items-center gap-2 font-semibold text-lg text-neutral-900 no-underline">
            <span class="text-primary-500 text-xl">◆</span>
            <span>AI Trend Daily</span>
          </a>
          <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-neutral-600">
            <a href="/firstblood/" class="hover:text-primary-500 transition-colors no-underline">今日趋势</a>
            <a href="/firstblood/category" class="hover:text-primary-500 transition-colors no-underline">分类浏览</a>
            <a href="/firstblood/report" class="hover:text-primary-500 transition-colors no-underline">历史报告</a>
          </nav>
          <div class="flex items-center gap-3">
            <span class="text-sm text-neutral-400">{currentDate}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-200 mt-12 py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-neutral-400">
        <p>AI Trend Daily · 开源 · 数据来源于 GitHub Trending</p>
        <p class="mt-1">
          <a href="https://github.com/liuyang/firstblood" class="hover:text-primary-500 transition-colors no-underline">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>
