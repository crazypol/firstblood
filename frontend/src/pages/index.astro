---
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/StatCard.astro';
import RepoCard from '../components/RepoCard.astro';
import CategoryChart from '../components/CategoryChart.astro';
import LanguageBar from '../components/LanguageBar.astro';
import fs from 'fs';
import path from 'path';

let report: any = null;
const latestPath = path.resolve('../data/reports/latest.json');
try {
  if (fs.existsSync(latestPath)) {
    report = JSON.parse(fs.readFileSync(latestPath, 'utf-8'));
  }
} catch {}

const hasData = report && report.total_repos > 0;
const topRepos = report?.top_repos?.slice(0, 10) || [];
const newEntrants = report?.new_entrants || [];
const categories = report?.categories || [];
const languages = report?.languages || [];
const insight = report?.insight_zh || '';
---

<Layout title="今日趋势">
  <!-- Hero Stats -->
  <section class="animate-fade-in">
    <div class="flex items-baseline justify-between mb-6">
      <div>
        <h1 class="apple-section-title">今日概览</h1>
        <p class="apple-section-subtitle">GitHub AI 项目每日趋势</p>
      </div>
      {hasData && (
        <span class="apple-pill bg-[var(--color-apple-blue-light)] text-[var(--color-apple-blue)] font-semibold">{report.date}</span>
      )}
    </div>

    {hasData ? (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        <StatCard label="AI 项目" value={report.total_ai_repos} color="text-[#8b5cf6]" />
        <StatCard label="分类数" value={categories.length} color="text-[#0098b3]" />
        {categories.length > 0 && (
          <StatCard label="最热分类" value={categories[0].name} trend={`${categories[0].count} 个项目`} color="text-[#b26200]" />
        )}
        {newEntrants.length > 0 && (
          <StatCard label="新星项目" value={newEntrants.length} trend="今日新上榜" />
        )}
      </div>
    ) : (
      <div class="apple-card p-10 text-center">
        <p class="text-lg font-semibold text-[var(--color-apple-text-secondary)] mb-2">暂无数据</p>
        <p class="text-sm text-[var(--color-apple-text-tertiary)]">运行 <code class="px-2 py-1 bg-[var(--color-apple-gray-fill)] rounded-lg text-xs font-mono">python -m src.pipeline</code> 获取今日数据</p>
      </div>
    )}
  </section>

  <!-- Insight -->
  {insight && (
    <section class="animate-fade-in">
      <div class="bg-[var(--color-apple-blue-light)] rounded-2xl px-6 py-5">
        <div class="flex items-start gap-3.5">
          <span class="text-xl leading-none mt-0.5">🤖</span>
          <div>
            <p class="text-sm font-semibold text-[var(--color-apple-blue)] mb-1">AI 今日洞察</p>
            <p class="text-sm text-[var(--color-apple-text)] leading-relaxed">{insight}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 animate-fade-in">
    {categories.length > 0 && <CategoryChart categories={categories} />}
    {languages.length > 0 && <LanguageBar languages={languages} />}
  </div>

  <!-- Top 10 -->
  {topRepos.length > 0 && (
    <section class="animate-fade-in">
      <h2 class="apple-section-title mb-1">热门 Top 10</h2>
      <p class="apple-section-subtitle mb-5">今日涨幅最高的 AI 开源项目</p>
      <div class="space-y-3">
        {topRepos.map((repo: any) => <RepoCard repo={repo} />)}
      </div>
    </section>
  )}

  <!-- New Entrants -->
  {newEntrants.length > 0 && (
    <section class="animate-fade-in">
      <h2 class="apple-section-title mb-1">新星项目</h2>
      <p class="apple-section-subtitle mb-5">首次登上趋势榜的项目</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {newEntrants.slice(0, 6).map((repo: any) => (
          <div class="apple-card px-5 py-4 flex items-center gap-3.5">
            <span class="apple-pill bg-[var(--color-apple-blue)] text-white text-[0.625rem] font-semibold shrink-0 px-2.5">NEW</span>
            <div class="min-w-0 flex-1">
              <a href={repo.url} target="_blank" class="text-sm font-semibold text-[var(--color-apple-text)] hover:text-[var(--color-apple-blue)] transition-colors duration-200 truncate block no-underline">
                {repo.name}
              </a>
              <p class="text-xs text-[var(--color-apple-text-tertiary)] truncate mt-0.5">{(repo.summary_zh || repo.description)?.slice(0, 60)}</p>
            </div>
            <span class="text-sm font-semibold text-[var(--color-success)] shrink-0 tabular-nums">+{repo.stars_today}</span>
          </div>
        ))}
      </div>
    </section>
  )}
</Layout>
