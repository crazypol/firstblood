---
import Layout from '../layouts/Layout.astro';
import RepoCard from '../components/RepoCard.astro';
import fs from 'fs';
import path from 'path';

let report: any = null;
const latestPath = path.resolve('../data/reports/latest.json');
try {
  if (fs.existsSync(latestPath)) {
    report = JSON.parse(fs.readFileSync(latestPath, 'utf-8'));
  }
} catch {}

const categories = report?.categories || [];
const allRepos = report?.top_repos || [];
const activeCat = Astro.url.searchParams.get('cat') || '';
const filteredRepos = activeCat ? allRepos.filter((r: any) => r.ai_category === activeCat) : allRepos;
---

<Layout title="分类浏览">
  <section class="animate-fade-in">
    <h1 class="apple-section-title mb-1">分类浏览</h1>
    <p class="apple-section-subtitle mb-6">按 AI 子领域筛选浏览热门项目</p>

    <!-- Pills -->
    <div class="flex flex-wrap gap-2 mb-6">
      <a href="/firstblood/category"
        class={`apple-pill text-sm font-medium no-underline transition-all duration-200 ${
          !activeCat ? 'apple-pill-active' : 'apple-pill-inactive'
        }`}>全部</a>
      {categories.map((cat: any) => {
        const isActive = activeCat === cat.name;
        return (
          <a href={`/firstblood/category?cat=${cat.name}`}
            class={`apple-pill text-sm font-medium no-underline transition-all duration-200 ${
              isActive ? 'apple-pill-active' : 'apple-pill-inactive'
            }`}>
            {cat.name}
            <span class="ml-1 opacity-70">({cat.count})</span>
          </a>
        );
      })}
    </div>

    {filteredRepos.length > 0 ? (
      <div class="space-y-3">
        {filteredRepos.map((repo: any) => <RepoCard repo={repo} />)}
      </div>
    ) : (
      <div class="apple-card p-12 text-center">
        <p class="text-lg font-semibold text-[var(--color-apple-text-secondary)] mb-2">暂无项目</p>
        <p class="text-sm text-[var(--color-apple-text-tertiary)]">该分类下暂无数据</p>
      </div>
    )}
  </section>
</Layout>
